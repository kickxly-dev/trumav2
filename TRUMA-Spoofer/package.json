{
  "name": "truma-spoofer",
  "version": "1.0.0",
  "description": "TRUMA Hardware ID and MAC Address Spoofer",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "dist:win": "electron-builder --win --x64"
  },
  "build": {
    "appId": "com.truma.spoofer",
    "productName": "TRUMA Spoofer",
    "directories": {
      "output": "output"
    },
    "files": [
      "main.js",
      "preload.js",
      "index.html",
      "renderer.js",
      "styles.css"
    ],
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowElevation": true,
      "runAfterFinish": true
    }
  },
  "devDependencies": {
    "electron": "^30.0.0",
    "electron-builder": "^24.13.3"
  }
}
