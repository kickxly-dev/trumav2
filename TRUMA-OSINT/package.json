{
  "name": "truma-osint",
  "version": "2.0.0",
  "description": "TRUMA OSINT - Self-Contained Open Source Intelligence Tool",
  "main": "osint.js",
  "bin": "osint.js",
  "scripts": {
    "start": "node osint.js",
    "build": "pkg . --targets node18-win-x64 --output dist/TRAUMA-OSINT.exe",
    "build:all": "pkg . --targets node18-win-x64,node18-linux-x64,node18-macos-x64 --out-path dist",
    "build:win": "pkg . --targets node18-win-x64 --output dist/TRAUMA-OSINT.exe"
  },
  "dependencies": {},
  "devDependencies": {
    "@yao-pkg/pkg": "^5.11.5"
  },
  "pkg": {
    "assets": [
      "license.js",
      "license-manager.js",
      "api-config.js",
      "report-template.js",
      "licenses/**/*",
      "results/**/*",
      "reports/**/*",
      "cache/**/*"
    ],
    "scripts": [
      "osint.js",
      "license.js",
      "license-manager.js",
      "api-config.js",
      "report-template.js"
    ],
    "targets": ["node18-win-x64"],
    "outputPath": "dist"
  }
}
